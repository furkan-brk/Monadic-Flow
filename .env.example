# ============================================================
# ParallelPulse — Root .env template
#
# Copy to .env and fill in real values before running.
# This file is safe to commit — .env is gitignored.
# ============================================================

# ── Blockchain ───────────────────────────────────────────────────────────────

# EVM RPC endpoint.
#   Dev  (Anvil in Docker): http://anvil:8545
#   Dev  (local port-fwd) : http://localhost:8545
#   Prod (Monad Testnet)  : https://testnet-rpc.monad.xyz
RPC_URL=http://anvil:8545

# Deployed EnergyMarket contract address.
#   Anvil deterministic address (account #0, nonce=0):
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Signing key for the deployer and simulation runner.
#   Anvil account #0 (DEV ONLY — never use on mainnet):
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Ethereum address of the BESS device.
#   Anvil account #0 public address (DEV ONLY):
BESS_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# ── Backend / Runner shared secret ───────────────────────────────────────────

# Shared secret between energy runner (POST /internal/soc) and backend.
# Change to a strong random value in production:
#   python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_TOKEN=parallelpulse-internal-secret

# ── Energy runner tuning ─────────────────────────────────────────────────────

# Seconds between SOC push cycles (default: 15).
SOC_PUSH_INTERVAL_S=15
