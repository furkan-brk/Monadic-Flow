# ============================================================
# ParallelPulse — .env şablonu
#
# Kopyala → .env, gerçek değerleri doldur:
#   cp .env.example .env
#
# Bu dosyayı commit etmek güvenlidir. .env gitignore'dadır.
# ============================================================

# ── Blockchain / Monad ──────────────────────────────────────────────────────
# Geliştirme (local Anvil): http://localhost:8545
# Üretim (Monad Testnet)  : https://testnet-rpc.monad.xyz
RPC_URL=https://testnet-rpc.monad.xyz

# forge script --broadcast çıktısından al.
# Anvil deterministik: 0x5FbDB2315678afecb367f032d93F642f64180aa3
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# İşlem imzalama anahtarı — ASLA gerçek key commit etme.
PRIVATE_KEY=0x...

# BESS cihazı Ethereum adresi.
BESS_ADDRESS=0x0000000000000000000000000000000000000001

# ── Backend ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
INTERNAL_TOKEN=change-me-use-secrets-token-hex-32

# ── Energy Runner ────────────────────────────────────────────────────────────
SOC_PUSH_INTERVAL_S=15
# Docker dışı: http://localhost:8000 | Docker: http://backend:8000
BACKEND_URL=http://localhost:8000
