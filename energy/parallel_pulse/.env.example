# Monad Testnet RPC endpoint
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Deployed EnergyMarket contract address (fill in after forge deploy)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Hot wallet private key for signing transactions (NEVER commit this file with real keys)
PRIVATE_KEY=0x...

# FastAPI backend base URL
# If running from WSL2 and backend is on Windows, use: http://172.31.32.1:8000
# (Get Windows IP: ip route show | grep default | awk '{print $3}')
BACKEND_URL=http://localhost:8000

# Must match INTERNAL_TOKEN in backend/.env
INTERNAL_TOKEN=parallelpulse-internal-secret

# Ethereum address representing the BESS device in the simulation
BESS_ADDRESS=0x0000000000000000000000000000000000000001

# Seconds between fault injection cycles (default: 30)
SOC_PUSH_INTERVAL_S=15
